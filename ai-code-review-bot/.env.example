# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_DIFF_SIZE_KB=500
MAX_FILES_PER_REVIEW=20

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | anthropic | azure_openai | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120

# ── LLM API Keys (set only the provider you use) ─────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI (if using azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Ollama (if using ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ── GitHub ────────────────────────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
# Set this in your GitHub App/webhook settings
GITHUB_WEBHOOK_SECRET=your-secret-here

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_TOKEN=glpat-...
GITLAB_WEBHOOK_SECRET=your-secret-here
GITLAB_BASE_URL=https://gitlab.com

# ── Review Behaviour ─────────────────────────────────────────────────────────
POST_INLINE_COMMENTS=true
POST_SUMMARY_COMMENT=true
# Minimum severity to post a comment: low | medium | high | critical
MIN_SEVERITY_TO_COMMENT=medium
